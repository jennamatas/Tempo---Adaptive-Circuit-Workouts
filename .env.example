# ─── Tempo environment variables ──────────────────────────────────────────────
# This file is the committed TEMPLATE. Copy it to `.env.local` and fill in real
# values for local development:
#
#   cp .env.example .env.local
#
# `.env.local` (and every other `.env*` file) is git-ignored; only this template
# is committed. Expo automatically loads `.env` / `.env.local` and inlines any
# `EXPO_PUBLIC_*` vars into the client bundle. If these are left unset, the app
# falls back to the bundled demo backend so a fresh clone still runs.

# ── Supabase (public — safe to ship in the client bundle) ─────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.databasepad.com
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Server-only secrets (NEVER prefix with EXPO_PUBLIC, NEVER commit) ──────────
# Used only by an out-of-band seed/admin script, not by the app itself.
# SUPABASE_SERVICE_ROLE_KEY=
